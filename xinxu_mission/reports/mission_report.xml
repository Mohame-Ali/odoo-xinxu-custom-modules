<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <report id="action_report_mission_order" string="Ordre de mission" model="mission.order" report_type="qweb-pdf"
            name="xinxu_mission.report_mission_order_template" file="xinxu_mission.report_mission_order_template"/>

    <template id="report_mission_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 12px;">
                        <!-- Header -->
                        <div style="text-align: center; margin-bottom: 20px;">
                            <h1>ORDRE DE MISSION</h1>
                        </div>

                        <!-- Employee details -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px;">
                            <tr>
                                <td style="width: 30%;"><strong>NOM, Prénom :</strong></td>
                                <td style="width: 70%;"><span t-field="doc.employee_id.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>FONCTIONS :</strong></td>
                                <td><span t-field="doc.function"/></td>
                            </tr>
                            <tr>
                                <td><strong>RESIDENCE PERSONNELLE :</strong></td>
                                <td><span t-field="doc.personal_address"/></td>
                            </tr>
                            <tr>
                                <td><strong>ACCOMPAGNÉ DE :</strong></td>
                                <td><span t-field="doc.accompanied_by"/></td>
                            </tr>
                            <tr>
                                <td><strong>MODALITÉS PARTICULIERES :</strong></td>
                                <td><span t-field="doc.particular_modalities"/></td>
                            </tr>
                        </table>

                        <!-- Destinations table -->
                        <table style="width: 100%; border-collapse: collapse; border: 1px solid black; margin-bottom: 15px;">
                            <thead>
                                <tr style="background-color: #f0f0f0;">
                                    <th style="border: 1px solid black; padding: 4px;">Lieu de Destination</th>
                                    <th style="border: 1px solid black; padding: 4px;">Date et Heure de DEPART</th>
                                    <th style="border: 1px solid black; padding: 4px;">Date et Heure de RETOUR</th>
                                    <th style="border: 1px solid black; padding: 4px;">Lieu de départ</th>
                                    <th style="border: 1px solid black; padding: 4px;">Lieu de retour</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.stage_ids" t-as="stage">
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="stage.destination"/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="stage.departure_datetime"/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="stage.return_datetime"/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="stage.departure_location"/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="stage.return_location"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Motif -->
                        <p><strong>MOTIF DU DEPLACEMENT :</strong> <span t-field="doc.purpose"/></p>

                        <!-- Moyen de transport -->
                        <p><strong>MOYEN DE TRANSPORT :</strong></p>
                        <div t-if="doc.transport_mode == 'vehicle_service'">
                            <p>☑ Autorisation d'utilisation d'un véhicule de service</p>
                        </div>
                        <div t-if="doc.transport_mode == 'personal_vehicle'">
                            <p>☑ Autorisation d'utilisation du véhicule personnel :</p>
                            <p>Marque : <span t-field="doc.vehicle_brand"/> — N° Immatriculation : <span t-field="doc.vehicle_plate"/></p>
                            <p>Remboursement : <span t-field="doc.personal_vehicle_reimbursement" widget="selection"/></p>
                        </div>
                        <div t-if="doc.transport_mode == 'public_transport'">
                            <p>☑ Prise en charge des titres de transport sur la base du transport le moins onéreux</p>
                        </div>
                        <div t-if="doc.transport_mode == 'actual_expenses'">
                            <p>☑ Prise en charge des frais réels (mission exceptionnelle)</p>
                        </div>

                        <!-- Frais -->
                        <h3>Note de frais</h3>
                        <table style="width: 100%; border-collapse: collapse; border: 1px solid black;">
                            <thead>
                                <tr style="background-color: #f0f0f0;">
                                    <th style="border: 1px solid black; padding: 4px;">Restauration</th>
                                    <th style="border: 1px solid black; padding: 4px;">Transport</th>
                                    <th style="border: 1px solid black; padding: 4px;">Frais divers</th>
                                    <th style="border: 1px solid black; padding: 4px;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="doc.total_restauration" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="doc.total_transport" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="doc.total_divers" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                    <td style="border: 1px solid black; padding: 4px;"><span t-field="doc.total_expenses" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Signature lines -->
                        <p style="margin-top: 20px;">Fait à Ben Arous, le <span t-field="doc.request_date"/></p>
                        <table style="width: 100%; margin-top: 40px;">
                            <tr>
                                <td style="width: 50%;">Visa demandeur : ____________________</td>
                                <td style="width: 50%;">Visa responsable : ____________________</td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>