<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action -->
    <record id="action_mission_order" model="ir.actions.act_window">
        <field name="name">Ordres de mission</field>
        <field name="res_model">mission.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez un nouvel ordre de mission.
            </p>
            <p>
                Les ordres de mission permettent de demander et suivre les déplacements professionnels.
                Les notes de frais peuvent être liées à un ordre de mission approuvé.
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_mission_root" name="Missions" parent="hr_expense.menu_hr_expense_root" sequence="15"/>
    <menuitem id="menu_mission_order" name="Ordres de mission" parent="menu_mission_root" action="action_mission_order"/>

    <!-- ====================== VUE LISTE ====================== -->
    <record id="view_mission_order_list" model="ir.ui.view">
        <field name="name">mission.order.list</field>
        <field name="model">mission.order</field>
        <field name="arch" type="xml">
            <list string="Ordres de mission">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="state" widget="badge"
                       decoration-danger="state=='refused'"
                       decoration-success="state=='approved'"/>
                <field name="approved_budget" sum="Budget total"/>
                <field name="spent_amount" sum="Dépensé"/>
                <field name="remaining_budget" sum="Reste"/>
            </list>
        </field>
    </record>

    <!-- ====================== VUE FORMULAIRE ====================== -->
    <record id="view_mission_order_form" model="ir.ui.view">
        <field name="name">mission.order.form</field>
        <field name="model">mission.order</field>
        <field name="arch" type="xml">
            <form string="Ordre de mission">
                <header>
                    <button name="action_submit" string="Soumettre" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_approve" string="Approuver" type="object"
                            groups="xinxu_mission.group_mission_manager"
                            invisible="state != 'submitted' or employee_id.user_id == uid"
                            class="btn-success"/>
                    <button name="action_refuse" string="Refuser" type="object"
                            groups="xinxu_mission.group_mission_manager"
                            invisible="state != 'submitted' or employee_id.user_id == uid"
                            class="btn-danger"/>
                    <button name="action_reset_to_draft" string="Remettre en brouillon" type="object"
                            invisible="state != 'refused'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,refused" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <group>
                            <group>
                                <field name="employee_id" options="{'no_create': True}"/>
                                <field name="function"/>
                                <field name="personal_address"/>
                                <field name="accompanied_by"/>
                                <field name="particular_modalities"/>
                            </group>
                            <group>
                                <field name="request_date"/>
                                <field name="state" readonly="1"/>
                                <field name="manager_id" readonly="1"/>
                                <field name="approval_date" readonly="1"/>
                            </group>
                        </group>
                    </div>

                    <notebook>
                        <!-- Destinations -->
                        <page string="Destinations">
                            <field name="stage_ids" mode="list,form">
                                <list string="Étapes" editable="bottom">
                                    <field name="destination"/>
                                    <field name="departure_datetime"/>
                                    <field name="return_datetime"/>
                                    <field name="departure_location"/>
                                    <field name="return_location"/>
                                </list>
                                <form string="Étape">
                                    <group>
                                        <field name="destination"/>
                                        <field name="departure_datetime"/>
                                        <field name="return_datetime"/>
                                    </group>
                                    <group string="Lieux">
                                        <field name="departure_location"/>
                                        <field name="return_location"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <!-- Motif et transport -->
                        <page string="Motif et transport">
                            <group>
                                <field name="purpose" widget="textarea"/>
                                <field name="transport_mode"/>
                                <field name="vehicle_brand"
                                      invisible="transport_mode != 'personal_vehicle'"
                                      required="transport_mode == 'personal_vehicle'"/>
                                <field name="vehicle_plate"
                                      invisible="transport_mode != 'personal_vehicle'"/>
                                <field name="personal_vehicle_reimbursement"
                                      invisible="transport_mode != 'personal_vehicle'"/>
                            </group>
                        </page>

                        <!-- Budget -->
                        <page string="Budget">
                            <group>
                                <group>
                                    <field name="estimated_costs"/>
                                    <field name="approved_budget"
                                           readonly="state not in ('submitted', 'approved')"/>
                                </group>
                                <group>
                                    <field name="spent_amount"/>
                                    <field name="remaining_budget"/>
                                </group>
                            </group>
                        </page>

                        <!-- Notes de frais -->
                        <page string="Notes de frais">
                            <field name="expense_ids" mode="list,form">
                                <list string="Dépenses liées">
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="total_amount"/>
                                    <field name="state" widget="badge"/>
                                </list>
                                <form string="Dépense">
                                    <group>
                                        <field name="name"/>
                                        <field name="product_id"/>
                                        <field name="total_amount"/>
                                        <field name="state"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

</odoo>