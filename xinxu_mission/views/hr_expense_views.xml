<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue formulaire des notes de frais : ajout du champ mission_id -->
    <record id="view_hr_expense_form_inherit" model="ir.ui.view">
        <field name="name">hr.expense.form.inherit.mission</field>
        <field name="model">hr.expense</field>
        <!-- ID CORRECT pour Odoo 18 -->
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="after">
                <field name="mission_id"
                       invisible="employee_id == False"
                       options="{'no_create': True}"/>
            </field>
        </field>
    </record>

</odoo>