<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_sale_order_form_xinxu_calcul" model="ir.ui.view">
    <field name="name">sale.order.form.xinxu.calcul</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

        <!-- Devise field in header (editable) -->
        <xpath expr="//field[@name='partner_id']" position="after">
            <field name="currency_id" string="Devise" options="{'no_create': True}" readonly="0"/>
        </xpath>

        <!-- Type de calcul before partner -->
        <xpath expr="//field[@name='partner_id']" position="before">
            <field name="xinxu_calc_type"
                   widget="radio"
                   options="{'horizontal': true}"/>
        </xpath>

        <!-- Smart button for supplier POs -->
        <xpath expr="//div[@name='button_box']" position="inside">
            <button name="action_view_xinxu_purchases"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-shopping-cart"
                    invisible="xinxu_purchase_count == 0">
                <field name="xinxu_purchase_count"
                       widget="statinfo"
                       string="BC Fournisseur(s)"/>
            </button>
        </xpath>

        <!-- Technical fields for button -->
        <xpath expr="//field[@name='partner_id']" position="before">
            <field name="xinxu_purchase_ids" invisible="1"/>
            <field name="xinxu_purchase_count" invisible="1"/>
        </xpath>

        <!-- Button to create supplier PO -->
        <xpath expr="//button[@name='action_confirm']" position="after">
            <button name="action_xinxu_create_purchase_order"
                    string="Créer le BC Fournisseur"
                    type="object"
                    class="btn-primary"
                    invisible="state not in ('sale', 'done')"/>
        </xpath>
        
        <!-- Add delivery mode field to the "other_information" page -->
        <xpath expr="//page[@name='other_information']" position="inside">
            <group string="XINXU Info">
                <field name="xinxu_delivery_mode"/>
            </group>
        </xpath> 

        <!-- Tableau de Calcul tab -->
        <xpath expr="//page[@name='order_lines']" position="after">
            <page string="Tableau de Calcul" name="xinxu_calcul">

                <!-- Local table -->
                <group invisible="xinxu_calc_type != 'local'">
                    <field name="order_line"
                           widget="one2many"
                           nolabel="1"
                           string="Tableau de Calcul — Client Local">
                        <list editable="bottom">
                            <!-- Identification (keep column headers) -->
                            <field name="product_id" optional="show"/>
                            <field name="x_supplier_id" string="Fournisseur retenu" optional="show"/>
                            <field name="x_delivery_time" string="Délai" optional="show"/>

                            <!-- Input fields – remove explicit string, model label will appear -->
                            <field name="x_supplier_price" optional="show"/>
                            <field name="x_customs_duties_pct" optional="show" widget="percentage"/>
                            <field name="x_conversion_rate" optional="show"/>
                            <field name="x_fodec_pct" optional="show" widget="percentage"/>
                            <field name="x_impot_douane_pct" optional="show" widget="percentage"/>
                            <field name="x_avance_import_pct" optional="show" widget="percentage"/>
                            <field name="x_margin_pct" optional="show" widget="percentage"/>
                            <field name="x_tva_pct" optional="show" widget="percentage"/>
                            <field name="product_uom_qty" optional="show"/>

                            <!-- Calculated fields – model labels will be used -->
                            <field name="x_total_price_orig" readonly="1" optional="show"/>
                            <field name="x_price_tnd" readonly="1" optional="show"/>
                            <field name="x_price_fodec" readonly="1" optional="show"/>
                            <field name="x_price_all_taxes" readonly="1" optional="show"/>
                            <field name="x_total_cost_tnd" readonly="1" optional="show"/>
                            <field name="x_prix_htva" readonly="1" optional="show"/>
                            <field name="x_marge_unitaire" readonly="1" optional="show"/>
                            <field name="x_montant_tva" readonly="1" optional="show"/>
                            <field name="x_prix_ttc" readonly="1" optional="show"/>
                            <field name="x_prix_total_ttc" readonly="1" optional="show"/>
                            <field name="x_marge_total_local" readonly="1" optional="show"/>
                        </list>
                    </field>
                </group>

                <!-- Foreign table -->
                <group invisible="xinxu_calc_type != 'foreign'">
                    <field name="order_line"
                           widget="one2many"
                           nolabel="1"
                           string="Tableau de Calcul — Client Étranger">
                        <list editable="bottom">
                            <!-- Identification -->
                            <field name="product_id" optional="show"/>
                            <field name="x_supplier_id" string="Fournisseur retenu" optional="show"/>
                            <field name="x_delivery_time" string="Délai" optional="show"/>

                            <!-- Input fields -->
                            <field name="x_supplier_price" optional="show"/>
                            <field name="x_conversion_rate" optional="show"/>
                            <field name="x_margin_pct" optional="show" widget="percentage"/>
                            <field name="product_uom_qty" optional="show"/>

                            <!-- Calculated fields – model labels will be used -->
                            <field name="x_price_eur" readonly="1" optional="show"/>
                            <field name="x_unit_sell_price_eur" readonly="1" optional="show"/>
                            <field name="x_prix_total_eur" readonly="1" optional="show"/>
                            <field name="x_margin_value_eur" readonly="1" optional="show"/>
                            <field name="x_marge_total_eur" readonly="1" optional="show"/>
                        </list>
                    </field>
                </group>

            </page>           
        </xpath>

    </field>
</record>

</odoo>