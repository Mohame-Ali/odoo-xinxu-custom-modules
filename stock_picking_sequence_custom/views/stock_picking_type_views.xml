<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_picking_type_form" model="ir.ui.view">
        <field name="name">stock.picking.type.form (custom sequence)</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sequence_id']" position="after">
                <field name="custom_sequence_id" placeholder="Séquence personnalisée"/>
            </xpath>
        </field>
    </record>
</odoo>