<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_xinxu" model="ir.ui.view">
        <field name="name">res.company.form.xinxu</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="XINXU Banking" name="xinxu_bank">
                    <group>
                        <field name="xinxu_rib"/>
                        <field name="xinxu_bank_name"/>
                        <field name="xinxu_bank_agency"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_xinxu" model="ir.ui.view">
        <field name="name">account.move.form.xinxu</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="XINXU Export" name="xinxu_export">
                    <group>
                        <field name="xinxu_delivery_mode"/>
                        <field name="xinxu_origin_of_goods"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>