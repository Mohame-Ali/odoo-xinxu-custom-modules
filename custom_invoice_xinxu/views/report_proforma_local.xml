<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_xinxu_invoice" model="report.paperformat">
        <field name="name">Xinxu A4 Invoice</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_xinxu_proforma_local" model="ir.actions.report">
        <field name="name">Proforma Invoice (client local)</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_invoice_xinxu.report_xinxu_proforma_local_document</field>
        <field name="report_file">custom_invoice_xinxu.report_xinxu_proforma_local_document</field>
        <field name="paperformat_id" ref="paperformat_xinxu_invoice"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'proforma_client_local_%s' % (object.name)</field>
    </record>

    <template id="report_xinxu_proforma_local_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page"
                         style="font-family: Arial, sans-serif; font-size: 11px; color: #000;">
                        <t t-set="cbank" t-value="doc.company_id.partner_id.bank_ids[:1]"/>

                        <!-- SECTION 1 – COMPANY HEADER -->
                        <table width="100%"
                               style="border-bottom: 2px solid #000;
                                      margin-bottom: 6px;
                                      border-collapse: collapse;">
                               <tr>
                                <td style="vertical-align: top; width: 65%;
                                           padding: 0 8px 6px 0;">
                                    <h1 style="font-size: 26px; font-weight: 900;
                                               letter-spacing: 2px;
                                               text-transform: uppercase;
                                               margin: 0 0 6px 0; color: #000;">
                                        <t t-esc="doc.company_id.name"/>
                                    </h1>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        Address&#160;:&#160;<t t-esc="doc.company_id.street or ''"/>
                                        <t t-if="doc.company_id.zip">
                                            ,&#160;<t t-esc="doc.company_id.zip"/>
                                        </t>
                                        <t t-if="doc.company_id.city">
                                            &#160;<t t-esc="doc.company_id.city"/>
                                        </t>
                                        <t t-if="doc.company_id.country_id">
                                            &#160;&#8211;&#160;<t t-esc="doc.company_id.country_id.name"/>
                                        </t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        RC&#160;:&#160;
                                        <t t-esc="doc.company_id.company_registry or '-'"/>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        MF&#160;:&#160;
                                        <t t-esc="doc.company_id.vat or '-'"/>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        IBAN&#160;:&#160;
                                        <t t-if="cbank">
                                            <t t-esc="'TN59 ' + cbank[0].acc_number or '-'"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        CODE SWIFT (Bic)&#160;:&#160;
                                        <t t-if="cbank and cbank[0].bank_id and cbank[0].bank_id.bic">
                                            <t t-esc="cbank[0].bank_id.bic"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        RIB&#160;:&#160;
                                        <t t-if="cbank">
                                            <t t-esc="cbank[0].acc_number or '-'"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        Banque&#160;:&#160;
                                        <t t-if="cbank and cbank[0].bank_id and cbank[0].bank_id.name">
                                            <t t-esc="cbank[0].bank_id.name"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                    <p style="margin: 8px 0 4px 0;">
                                        <span style="font-weight: bold;">Tel&#160;:</span>
                                        &#160;<t t-esc="doc.company_id.phone or '-'"/>
                                        &#160;&#160;&#160;
                                        <span style="font-weight: bold;"><em>Email&#160;:</em></span>
                                        &#160;<t t-esc="doc.company_id.email or '-'"/>
                                    </p>
                                 </td>
                                <td style="vertical-align: top; text-align: right;
                                           width: 35%; padding: 0 0 6px 0;">
                                    <t t-if="doc.company_id.logo">
                                        <img t-att-src="'/web/image/res.company/%s/logo'
                                                        % doc.company_id.id"
                                             style="max-height: 90px; max-width: 180px;"
                                             alt="Logo"/>
                                    </t>
                                 </td>
                               </tr>
                           </table>

                        <!-- SECTION 2 – INVOICE TITLE BAR -->
                        <table width="100%"
                               style="margin-bottom: 6px; border-collapse: collapse;">
                               <tr>
                                <td style="text-align: center; width: 70%;
                                           vertical-align: middle;">
                                    <span style="font-weight: 900; font-size: 14px;
                                                 letter-spacing: 1px;
                                                 text-transform: uppercase;">
                                        PROFORMA INVOICE N&#176;&#160;:&#160;
                                        <t t-esc="doc.name"/>
                                    </span>
                                 </td>
                                <td style="text-align: right; width: 30%;
                                           vertical-align: middle;">
                                    <span style="font-weight: bold; font-size: 11px;">
                                        DATE&#160;:&#160;
                                        <span t-field="doc.date_order"
                                              t-options='{"widget": "date"}'/>
                                    </span>
                                 </td>
                               </tr>
                           </table>

                        <!-- SECTION 3 – CLIENT BLOCK -->
                        <table width="100%"
                               style="border: 1px solid #000;
                                      margin-bottom: 10px;
                                      border-collapse: collapse;">
                               <tr>
                                <td style="vertical-align: top; width: 65%;
                                           padding: 4px 8px;">
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        Client&#160;:&#160;
                                        <t t-esc="doc.partner_id.name or '-'"/>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        Adresse&#160;:&#160;
                                        <t t-if="doc.partner_id.street">
                                            <t t-esc="doc.partner_id.street"/>
                                            <t t-if="doc.partner_id.street2">, <t t-esc="doc.partner_id.street2"/></t>
                                        </t>
                                        <t t-if="doc.partner_id.city">, <t t-esc="doc.partner_id.city"/></t>
                                        <t t-if="doc.partner_id.zip"> <t t-esc="doc.partner_id.zip"/></t>
                                        <t t-if="doc.partner_id.country_id">, <t t-esc="doc.partner_id.country_id.name"/></t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        MF&#160;:&#160;
                                        <t t-esc="doc.partner_id.vat or '-'"/>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        Email&#160;:&#160;
                                        <t t-esc="doc.partner_id.email or '-'"/>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        T&#201;L&#201;PHONE&#160;:&#160;
                                        <t t-esc="doc.partner_id.phone or '-'"/>
                                    </p>
                                 </td>
                                <td style="vertical-align: top; width: 35%;
                                           padding: 4px 8px;">
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        Code client&#160;:&#160;
                                        <t t-esc="doc.partner_id.ref or '-'"/>
                                    </p>
                                 </td>
                               </tr>
                           </table>

                        <!-- SECTION 4 – ORDER LINES TABLE (single table to lock alignment) -->
                        <table width="100%" style="border-collapse: collapse; table-layout: fixed; font-size: 11px; margin-bottom: 0;">
                            <colgroup>
                                <col style="width:4%;"/>
                                <col style="width:18%;"/>
                                <col style="width:14%;"/>
                                <col style="width:11%;"/>
                                <col style="width:5%;"/>
                                <col style="width:12%;"/>
                                <col style="width:7%;"/>
                                <col style="width:12%;"/>
                                <col style="width:5%;"/>
                                <col style="width:12%;"/>
                            </colgroup>
                            <thead>
                                <tr style="background-color: #d9d9d9;">
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">N&#176;</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Article</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Model</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Photo</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Unit</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Prix Unitaire<br/>HTVA</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Tva (%)</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Prix Unitaire<br/>TTC (<t t-esc="doc.currency_id.name"/>)</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Qty</th>
                                    <th style="border:1px solid #000; padding:5px 4px; text-align:center; font-weight:bold;">Prix Total TTC (<t t-esc="doc.currency_id.name"/>)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.order_line" t-as="line">
                                    <t t-set="tax_rate" t-value="(line.tax_id[0].amount / 100.0) if line.tax_id else 0.0"/>
                                    <t t-set="unit_ttc" t-value="line.price_unit * (1.0 + tax_rate)"/>
                                    <t t-set="total_ttc" t-value="line.price_subtotal * (1.0 + tax_rate)"/>
                                    <tr style="page-break-inside: avoid;">
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-esc="line_index + 1"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-esc="line.product_id.name or '-'"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-esc="line.product_id.default_code or '-'"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-if="line.product_id.image_128">
                                                <img t-att-src="'/web/image/product.product/%s/image_128' % line.product_id.id"
                                                     style="display:block; margin:0 auto; max-height:60px; max-width:100%; width:auto; height:auto;"
                                                     alt=""/>
                                            </t>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-if="line.product_uom">
                                                <t t-esc="line.product_uom.name"/>
                                            </t>
                                            <t t-else="">pc</t>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <span t-field="line.price_unit" t-options='{"widget":"monetary","display_currency":doc.currency_id}'/>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-if="line.tax_id">
                                                <t t-foreach="line.tax_id" t-as="tax">
                                                    <t t-esc="int(tax.amount)"/>%<t t-if="not tax_last">,&#160;</t>
                                                </t>
                                            </t>
                                            <t t-else="">-</t>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-esc="'%.3f' % unit_ttc"/>&#160;<span t-esc="doc.currency_id.symbol"/>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <span t-field="line.product_uom_qty" t-options='{"widget":"integer"}'/>
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 4px; text-align:center; vertical-align:middle;">
                                            <t t-esc="'%.3f' % total_ttc"/>&#160;<span t-esc="doc.currency_id.symbol"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- =========================================
                             TOTAL LINE (FOOTER)
                        ========================================= -->
                        <div style="page-break-inside: avoid;">
                            <table width="100%" style="border-collapse: collapse; font-size: 11px;">
                                <tfoot>
                                    <tr>
                                        <td colspan="9"
                                            style="border:1px solid #000; padding:5px 6px;
                                                   text-align:right; font-weight:bold;">
                                            Prix Total TTC
                                        </td>
                                        <td style="border:1px solid #000; padding:5px 6px;
                                                   text-align:center; font-weight:bold; width:12%;">
                                            <span t-field="doc.amount_total"
                                                  t-options='{"widget":"monetary",
                                                              "display_currency":doc.currency_id}'/>
                                        </td>
                                    </tr>
                                </tfoot>
                              </table>
                        </div>

                        <!-- SECTION 5 – FOOTER TERMS -->
                        <table width="100%"
                               style="margin-top: 8px; border-collapse: collapse;">
                               <tr>
                                <td style="vertical-align: top; padding: 4px 0;">
                                    <p style="margin: 2px 0; font-weight: bold; font-size: 10px;">
                                        Mode de livraison&#160;:&#160;
                                        <t t-if="doc.xinxu_delivery_mode">
                                            <span t-field="doc.xinxu_delivery_mode"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;
                                              font-size: 10px;">
                                        D&#233;lai de livraison&#160;:&#160;
                                        <t t-if="doc.commitment_date">
                                            <span t-field="doc.commitment_date"
                                                  t-options='{"widget": "date"}'/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                    <p style="margin: 2px 0; font-weight: bold;
                                              font-size: 10px;">
                                        Modalit&#233; de paiement&#160;:&#160;
                                        <t t-if="doc.payment_term_id">
                                            <t t-esc="doc.payment_term_id.name"/>
                                        </t>
                                        <t t-else="">-</t>
                                    </p>
                                 </td>
                               </tr>
                           </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>