<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_xinxu" model="ir.ui.view">
        <field name="name">res.partner.form.xinxu</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- new field inside the Sales & Purchases tab -->
            <xpath expr="//page[@name='sales_purchases']" position="inside">
                <group string="XINXU Specific">
                    <field name="x_ms_number"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>