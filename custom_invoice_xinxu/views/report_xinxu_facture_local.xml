<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         PAPER FORMAT
    ============================================================ -->
    <record id="paperformat_xinxu_facture_local" model="report.paperformat">
        <field name="name">Xinxu A4 Facture Local</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- ============================================================
         REPORT ACTION — account.move → Facturation > Imprimer
    ============================================================ -->
    <record id="action_report_xinxu_facture_local" model="ir.actions.report">
        <field name="name">Facture Client Local (Xinxu)</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_invoice_xinxu.report_xinxu_facture_local_document</field>
        <field name="report_file">custom_invoice_xinxu.report_xinxu_facture_local_document</field>
        <field name="paperformat_id" ref="paperformat_xinxu_facture_local"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'FACTURE_%s' % (object.name)</field>
    </record>

    <template id="report_xinxu_facture_local_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page"
                         style="font-family: Arial, sans-serif;
                                font-size: 10px; color: #000;">

                        <!-- ── Pré‑calcul des taxes séparées ── -->
                        <t t-set="all_tax_lines"
                           t-value="doc.line_ids.filtered(lambda l: l.tax_line_id)"/>
                        <t t-set="total_vat"
                           t-value="abs(sum(all_tax_lines.filtered(
                               lambda l: l.tax_line_id.amount_type == 'percent'
                           ).mapped('balance')))"/>
                        <t t-set="total_timbre"
                           t-value="abs(sum(all_tax_lines.filtered(
                               lambda l: l.tax_line_id.amount_type == 'fixed'
                           ).mapped('balance')))"/>

                        <!-- =========================================
                             SECTION 1 – EN‑TÊTE SOCIÉTÉ
                        ========================================= -->
                        <table width="100%"
                               style="border: 1px solid #000;
                                      border-collapse: collapse;
                                      margin-bottom: 0;">
                            <tr>
                                <!-- Logo -->
                                <td style="vertical-align: top;
                                           width: 18%;
                                           padding: 6px 8px;">
                                    <t t-if="doc.company_id.logo">
                                        <img t-att-src="'/web/image/res.company/%s/logo' % doc.company_id.id"
                                             style="max-height: 70px; max-width: 90px;" alt="Logo"/>
                                    </t>
                                </td>

                                <!-- Nom société centré -->
                                <td style="vertical-align: middle;
                                           text-align: center;
                                           width: 64%;
                                           padding: 6px 8px;">
                                    <span style="font-size: 22px;
                                                 font-weight: 900;
                                                 letter-spacing: 2px;
                                                 text-transform: uppercase;">
                                        <t t-esc="doc.company_id.name"/>
                                    </span>
                                </td>

                                <!-- Espace droit -->
                                <td style="width: 18%;"></td>
                            </tr>

                            <!-- Ligne d'info société (adresse, MF, RIB, banque, agence, téléphone, email) -->
                            <tr>
                                <td colspan="3"
                                    style="border-top: 1px solid #000;
                                           padding: 5px 10px;">
                                    <!-- Adresse -->
                                    <p style="margin: 1px 0; font-weight: bold;">
                                        <strong>Adresse&#160;:</strong>&#160;
                                        <t t-esc="doc.company_id.street or ''"/>
                                        <t t-if="doc.company_id.zip">,&#160;<t t-esc="doc.company_id.zip"/></t>
                                        <t t-if="doc.company_id.city">&#160;<t t-esc="doc.company_id.city"/></t>
                                        <t t-if="doc.company_id.country_id">&#160;&#8211;&#160;<t t-esc="doc.company_id.country_id.name"/></t>
                                    </p>
                                    <!-- Matricule Fiscale -->
                                    <p style="margin: 1px 0; font-weight: bold;">
                                        <strong>Matricule Fiscale&#160;:</strong>&#160;
                                        <t t-esc="doc.company_id.vat or '-'"/>
                                    </p>
                                    <!-- RIB, Banque, Agence (champs custom) -->
                                    <table width="100%" style="border-collapse: collapse;">
                                        <tr>
                                            <td style="padding: 0; width: 50%;">
                                                <p style="margin: 1px 0; font-weight: bold;">
                                                    <strong>RIB&#160;:</strong>&#160;
                                                    <span t-field="doc.company_id.xinxu_rib"/>
                                                </p>
                                                <p style="margin: 1px 0; font-weight: bold;">
                                                    <strong>Banque&#160;:</strong>&#160;
                                                    <span t-field="doc.company_id.xinxu_bank_name"/>
                                                </p>
                                                <p style="margin: 1px 0; font-weight: bold;">
                                                    <strong>Agence&#160;:</strong>&#160;
                                                    <span t-field="doc.company_id.xinxu_bank_agency"/>
                                                </p>
                                                <!-- Téléphone principal -->
                                                <p style="margin: 1px 0;">
                                                    <strong>Tél&#160;:</strong>&#160;
                                                    <t t-esc="doc.company_id.phone or '-'"/>
                                                    <span style="margin-left: 20px;">
                                                        <strong>Email&#160;:</strong>&#160;
                                                        <t t-esc="doc.company_id.email or '-'"/>
                                                    </span>
                                                </p> 
                                                <!-- Mobile (si disponible) -->
                                                <t t-if="doc.company_id.mobile">
                                                    <p style="margin: 1px 0;">
                                                        <strong>Tél&#160;:</strong>&#160;
                                                        <t t-esc="doc.company_id.mobile"/>
                                                    </p>
                                                </t>                                                                                               
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- =========================================
                             SECTION 2 – N° FACTURE + DATE
                        ========================================= -->
                        <table width="100%"
                               style="border: 1px solid #000;
                                      border-top: none;
                                      border-collapse: collapse;
                                      margin-bottom: 0;
                                      background-color: #f8f8f8;">
                            <tr>
                                <td style="text-align: center;
                                           font-weight: bold;
                                           font-size: 13px;
                                           letter-spacing: 1px;
                                           padding: 5px 8px;
                                           width: 60%;">
                                    FACTURE N&#176;&#160;:
                                    <t t-esc="doc.name"/>
                                </td>
                                <td style="text-align: right;
                                           font-weight: bold;
                                           font-size: 12px;
                                           padding: 5px 10px;
                                           width: 40%;">
                                    DATE&#160;:&#160;
                                    <t t-if="doc.invoice_date">
                                        <span t-field="doc.invoice_date"
                                              t-options='{"widget":"date","format":"dd/MM/yyyy"}'/>
                                    </t>
                                    <t t-else="">-</t>
                                </td>
                            </tr>
                        </table>

                        <!-- =========================================
                             SECTION 3 – BLOC CLIENT
                        ========================================= -->
                        <table width="100%"
                               style="border: 1px solid #000;
                                      border-top: none;
                                      border-collapse: collapse;
                                      margin-bottom: 8px;">
                            <tr>
                                <td style="vertical-align: top;
                                           width: 65%;
                                           padding: 5px 8px;
                                           border: none;">
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        <strong>Client&#160;:</strong>&#160;
                                        <span t-field="doc.partner_id.name"/>
                                    </p>
                                    <p style="margin: 2px 0;">
                                        <strong>Adresse&#160;:</strong>&#160;
                                        <t t-esc="doc.partner_id.street or ''"/>
                                        <t t-if="doc.partner_id.city">,&#160;<t t-esc="doc.partner_id.city"/></t>
                                        <t t-if="doc.partner_id.zip">&#160;<t t-esc="doc.partner_id.zip"/></t>
                                        <t t-if="doc.partner_id.country_id">,&#160;<t t-esc="doc.partner_id.country_id.name"/></t>
                                    </p>
                                    <t t-if="doc.partner_id.phone or doc.partner_id.mobile">
                                        <p style="margin: 2px 0;">
                                            <strong>TÉLÉPHONE&#160;:</strong>&#160;
                                            <t t-esc="doc.partner_id.phone or doc.partner_id.mobile"/>
                                        </p>
                                    </t>
                                    <t t-if="doc.partner_id.email">
                                        <p style="margin: 2px 0;">
                                            <strong>Email&#160;:</strong>&#160;
                                            <span t-field="doc.partner_id.email"/>
                                        </p>
                                    </t>
                                </td>

                                <!-- Code client -->
                                <td style="vertical-align: top;
                                           width: 35%;
                                           padding: 5px 8px;
                                           border: none;">
                                    <p style="margin: 2px 0; font-weight: bold;">
                                        <strong>Code client&#160;:</strong>&#160;
                                        <t t-esc="doc.partner_id.ref or ''"/>
                                    </p>
                                </td>
                            </tr>
                        </table>

                        <!-- =========================================
                             SECTION 4 – TABLEAU DES LIGNES
                        ========================================= -->
                        <table width="100%"
                               style="border-collapse: collapse;
                                      font-size: 10px;">
                            <thead>
                                <tr style="background-color: #e8e8e8;">
                                    <th style="border: 1px solid #000;
                                               padding: 5px 4px;
                                               text-align: center;
                                               width: 13%;">Référence</th>
                                    <th style="border: 1px solid #000;
                                               padding: 5px 4px;
                                               text-align: center;
                                               width: 37%;">Désignation</th>
                                    <th style="border: 1px solid #000;
                                               padding: 5px 4px;
                                               text-align: center;
                                               width: 10%;">Qté</th>
                                    <th style="border: 1px solid #000;
                                               padding: 5px 4px;
                                               text-align: center;
                                               width: 15%;">Prix U. HT</th>
                                    <th style="border: 1px solid #000;
                                               padding: 5px 4px;
                                               text-align: center;
                                               width: 10%;">% TVA</th>
                                    <th style="border: 1px solid #000;
                                               padding: 5px 4px;
                                               text-align: right;
                                               width: 15%;">Montant H.T</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.invoice_line_ids" t-as="line">
                                    <t t-if="line.display_type == 'product'">
                                        <tr>
                                            <td style="border: 1px solid #000;
                                                       padding: 5px 4px;
                                                       text-align: center;">
                                                <t t-esc="line.product_id.default_code or ''"/>
                                            </td>
                                            <td style="border: 1px solid #000;
                                                       padding: 5px 6px;
                                                       text-align: left;">
                                                <span t-field="line.name"/>
                                            </td>
                                            <td style="border: 1px solid #000;
                                                       padding: 5px 4px;
                                                       text-align: center;">
                                                <span t-field="line.quantity"
                                                      t-options='{"widget":"float","precision":1}'/>
                                            </td>
                                            <td style="border: 1px solid #000;
                                                       padding: 5px 4px;
                                                       text-align: right;">
                                                <span t-field="line.price_unit"
                                                      t-options='{"widget":"float","precision":3}'/>
                                            </td>
                                            <td style="border: 1px solid #000;
                                                       padding: 5px 4px;
                                                       text-align: center;">
                                                <t t-foreach="line.tax_ids" t-as="tax">
                                                    <t t-if="tax.amount_type == 'percent'">
                                                        <t t-esc="'%g' % tax.amount"/>%
                                                    </t>
                                                </t>
                                            </td>
                                            <td style="border: 1px solid #000;
                                                       padding: 5px 4px;
                                                       text-align: right;">
                                                <span t-field="line.price_subtotal"
                                                      t-options='{"widget":"float","precision":2}'/>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-elif="line.display_type == 'line_section'">
                                        <tr>
                                            <td colspan="6"
                                                style="border: 1px solid #000;
                                                       padding: 4px 6px;
                                                       font-weight: bold;
                                                       background-color: #f0f0f0;">
                                                <span t-field="line.name"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <t t-elif="line.display_type == 'line_note'">
                                        <tr>
                                            <td colspan="6"
                                                style="border: 1px solid #000;
                                                       padding: 4px 6px;
                                                       font-style: italic;">
                                                <span t-field="line.name"/>
                                            </td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>

                        <!-- =========================================
                             SECTION 5 – TOTAUX (bloc à droite)
                        ========================================= -->
                        <table width="100%" style="border-collapse: collapse; margin-top: 16px;">
                            <tr>
                                <td style="width: 55%; border: none;"></td>
                                <td style="width: 45%; padding: 0; vertical-align: top;">
                                    <table width="100%"
                                           style="border-collapse: collapse;
                                                  border: 1px solid #000;
                                                  border-top: none;">
                                        <tr>
                                            <td style="padding: 4px 8px;
                                                       border-top: 1px solid #000;
                                                       border-bottom: 1px solid #ccc;
                                                       font-weight: bold;">
                                                Total Hors Taxe
                                            </td>
                                            <td style="padding: 4px 8px;
                                                       text-align: right;
                                                       border-top: 1px solid #000;
                                                       border-bottom: 1px solid #ccc;
                                                       border-left: 1px solid #000;">
                                                <span t-field="doc.amount_untaxed"
                                                      t-options='{"widget":"float","precision":2}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 4px 8px;
                                                       border-bottom: 1px solid #ccc;">
                                                Total TVA
                                            </td>
                                            <td style="padding: 4px 8px;
                                                       text-align: right;
                                                       border-bottom: 1px solid #ccc;
                                                       border-left: 1px solid #000;">
                                                <t t-esc="'%.2f' % total_vat"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 4px 8px;
                                                       border-bottom: 1px solid #000;">
                                                Timbre
                                            </td>
                                            <td style="padding: 4px 8px;
                                                       text-align: right;
                                                       border-bottom: 1px solid #000;
                                                       border-left: 1px solid #000;">
                                                <t t-esc="'%.2f' % total_timbre"/>
                                            </td>
                                        </tr>
                                        <tr style="background-color: #f0f0f0;">
                                            <td style="padding: 5px 8px;
                                                       font-weight: bold;
                                                       font-size: 11px;">
                                                Total TTC
                                            </td>
                                            <td style="padding: 5px 8px;
                                                       text-align: right;
                                                       font-weight: bold;
                                                       font-size: 11px;
                                                       border-left: 1px solid #000;">
                                                <span t-field="doc.amount_total"
                                                      t-options='{"widget":"float","precision":2}'/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- =========================================
                             SECTION 6 – PIED DE PAGE (montant en lettres, livraison, règlement)
                        ========================================= -->
                        <div style="margin-top: 12px; font-size: 10px;">
                            <p style="margin: 3px 0;">
                                <strong>Arrêter la présente facture à la somme de&#160;:</strong>&#160;
                                <t t-if="doc.currency_id and doc.currency_id.amount_to_text">
                                    <span t-esc="doc.currency_id.amount_to_text(doc.amount_total)"/>
                                </t>
                            </p>
                            <p style="margin: 3px 0;">
                                <strong>Mode de livraison&#160;:</strong>&#160;
                                <span t-field="doc.xinxu_delivery_mode"/>
                            </p>
                            <p style="margin: 3px 0;">
                                <strong>Mode de règlement&#160;:</strong>&#160;
                                <t t-if="doc.invoice_payment_term_id">
                                    <span t-field="doc.invoice_payment_term_id.name"/>
                                </t>
                                <t t-else="">-</t>
                            </p>
                        </div>

                        <!-- =========================================
                             SECTION 7 – SIGNATURES (deux colonnes)
                        ========================================= -->
                        <table style="border-collapse: collapse;
                                      margin: 16px auto;">
                            <tr style="text-align: center;">
                                <!-- First box -->
                                <td style="border: 1px solid #000;
                                           width: 6cm;
                                           height: 80px;
                                           padding: 6px 8px;
                                           vertical-align: top;
                                           text-align: center;">
                                    <p style="margin: 0; font-weight: bold; font-size: 10px;">
                                        Signature et Cachet du Client
                                    </p>
                                    <p style="margin-top: 50px; font-weight: bold; font-size: 10px;">
                                        Reçue Conforme
                                    </p>                                   
                                </td>
                                <!-- Space between boxes -->
                                <td style="width: 10cm;"></td>
                                <!-- Second box -->
                                <td style="border: 1px solid #000;
                                           width: 6cm;
                                           height: 80px;
                                           padding: 6px 8px;
                                           vertical-align: top;
                                           text-align: center;">
                                    <p style="margin: 0; font-weight: bold; font-size: 10px;">
                                        Signature et Cachet
                                    </p>
                                </td>
                            </tr>
                        </table>

                    </div><!-- /page -->
                </t><!-- /web.external_layout -->
            </t><!-- /t-foreach docs -->
        </t><!-- /web.html_container -->
    </template>

</odoo>